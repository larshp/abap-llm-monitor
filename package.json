  "dependencies": {
    "@abaplint/cli": "^2.119.41",
    "@abaplint/runtime": "^2.13.30",
    "@abaplint/transpiler": "^2.13.30",
    "@abaplint/transpiler-cli": "^2.13.30",
    "@github/copilot-sdk": "^1.0.3",
    "electron": "^42.5.0",
    "express": "^4.22.2"
